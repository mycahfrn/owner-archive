---
import Layout from "@components/Layout.astro";
import Metatags from "@components/Metatags.astro";
import { getEntry, getCollection, render } from 'astro:content';
import { formattedDate } from "@utils/date";

export async function getStaticPaths() {
  const posts = await getCollection('posts');
  return posts.map((post) => ({ params: { slug: post.id } }));
}

const { slug } = Astro.params;
const post = await getEntry('posts', slug);
if (!post) {
  throw new Error('Post not found');
}
const { Content } = await render(post);
// Tipado explícito del frontmatter de la colección `posts`
interface PostFrontmatter {
  title: string;
  excerpt?: string;
  date?: string;
  description?: string;
  canonical?: string;
  image?: string; // campo preferido para imagen destacada
  imageAlt?: string;
  srcPreview?: string; // nombre usado en los placeholders existentes
  altPreview?: string;
}

const meta = post.data as PostFrontmatter;
const canonical = meta.canonical ?? `/owner-archive/posts/${slug}/`;
const title = meta.title;
const description = meta.description ?? meta.excerpt ?? '';
const image = (meta.image ?? meta.srcPreview) as string | undefined;
const imageAlt = (meta.imageAlt ?? meta.altPreview ?? title) as string;
---

<head>
  <Metatags
    title={title}
    description={description}
    canonical={canonical}
    image={image}
    imageAlt={imageAlt}
  />
</head>

<Layout title={post.data.title}>
    <div class="max-w-182 mx-auto px-4 py-8">
        <article class="prose prose-lg">
            <h1 class="text-[32px] text-primary font-title font-semibold ">{post.data.title}</h1>
            <p class="font-title text-button-tabs text-lg">{post.data.excerpt}</p>
            <time datetime={post.data.date} class="text-preview-date text-subtitle">{formattedDate(post.data.date)}</time>
            <div class="mt-6 text-primary text-title-post font-post">
                <Content />
            </div>
        </article>
    </div>
</Layout>
